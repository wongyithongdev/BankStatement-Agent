# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Provider (choose one) ──────────────────────────────────────────────────

# Option 1: Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Xiaomi MiMo (OpenAI-compatible)
# XIAOMI_API_KEY=your-key-here
# XIAOMI_BASE_URL=https://api.together.ai/v1

# Option 3: OpenRouter
# OPENROUTER_API_KEY=your-key-here

# ── Model ─────────────────────────────────────────────────────────────────
# Default provider used by the agent
# Options: anthropic | xiaomi | openrouter
PROVIDER=anthropic
