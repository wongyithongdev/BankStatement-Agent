# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Provider (choose one) ──────────────────────────────────────────────────

# Option 1: Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# Option 2: Xiaomi MiMo (OpenAI-compatible)
# XIAOMI_API_KEY=your-key-here
# XIAOMI_BASE_URL=https://api.together.ai/v1

# Option 3: OpenRouter
# OPENROUTER_API_KEY=your-key-here

PROVIDER=anthropic

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://root:root@10.0.10.63:5432/root

# ── Cache & SSE ────────────────────────────────────────────────────────────
REDIS_URL=redis://ubuntu:root@192.168.11.177:6379/0

# ── Auth Server ────────────────────────────────────────────────────────────
AUTH_SERVER_BASE=http://localhost:8080

# ── Storage ────────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/bankstatement/uploads
OUTPUT_DIR=/tmp/bankstatement/outputs

# ── Docker Sandbox ─────────────────────────────────────────────────────────
USE_DOCKER_SANDBOX=true
SANDBOX_IMAGE=bankstatement-sandbox:latest

# ── File Server ────────────────────────────────────────────────────────────
FILESERVER_URL=https://files.my365biz.com
FILESERVER_API_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all origins.
CORS_ORIGINS=https://app.my365biz.com

# ── Rate Limiting ──────────────────────────────────────────────────────────
GLOBAL_RPM_LIMIT=75
